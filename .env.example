# ═══════════════════════════════════════════════════════
# 筹码峰量化投研平台 - 环境变量示例
# ═══════════════════════════════════════════════════════
# 复制本文件为 .env 并填入实际值
#   cp .env.example .env   (Linux/Mac)
#   copy .env.example .env (Windows)

# ── Tushare Token (必填) ──
# 在 https://tushare.pro 注册获取
TUSHARE_TOKEN=your_tushare_token_here

# ── Flask Secret Key (生产环境必填，否则使用默认值不安全) ──
# 随机字符串，例如: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-me-in-production

# ── Flask 运行配置 (可选) ──
# FLASK_HOST=0.0.0.0
# FLASK_PORT=5000
# FLASK_DEBUG=0